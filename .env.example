APP_NAME=Personal Automation Hub
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=2.0.0
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
APP_API_KEY=change-me

DATABASE_URL=sqlite:///./automation_hub.db
SCHEDULER_POLL_SECONDS=30

# Daily summary digest
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_TIME_UTC=19:00
DAILY_SUMMARY_CHANNEL=telegram
DAILY_SUMMARY_TARGET=

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_BOT_POLLING_ENABLED=true
TELEGRAM_BOT_POLL_TIMEOUT_SECONDS=20

# Telegram Webhook mode (recommended for multi-server deployments).
# If set, the bot registers a webhook instead of long-polling.
# Must be a publicly reachable HTTPS URL ending in /api/telegram/webhook
# Generate the secret: python -c "import secrets; print(secrets.token_hex(32))"
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# Telegram Mini App URL — the public HTTPS URL of the /miniapp endpoint.
# Example: https://hub.kcpd.top/miniapp
# After setting this, call POST /miniapp/setmenu to register the bot's Menu Button in BotFather.
MINIAPP_URL=https://hub.kcpd.top/miniapp

# Notes encryption key (Fernet symmetric key).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NOTES_ENCRYPTION_KEY=

# Email channel (optional - for sending reminders via email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_USE_TLS=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=200/minute
